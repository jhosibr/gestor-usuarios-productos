                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Nuevo Producto\",\n  \"description\": \"Descripción del producto\",\n  \"category\": \"Electrónica\",\n  \"price\": 299.99,\n  \"stock\": 50\n}"
