{
  "info": {
    "name": "Sistema de Gestión de Usuarios y Productos",
    "description": "Colección de Postman para pruebas de API REST con Laravel 12",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
