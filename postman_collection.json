          }
        },
        {
          "name": "Buscar Productos",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/products/search?q=laptop",
              "host": ["{{baseUrl}}"],
              "path": ["products", "search"],
              "query": [
                {
                  "key": "q",
                  "value": "laptop"
                }
              ]
