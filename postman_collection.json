            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Producto Actualizado\",\n  \"price\": 349.99,\n  \"stock\": 75\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/products/1",
              "host": ["{{baseUrl}}"],
              "path": ["products", "1"]
            }
          }
        },
        {
          "name": "Eliminar Producto",
          "request": {
            "method": "DELETE",
