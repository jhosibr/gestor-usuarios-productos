    {
      "name": "Productos",
      "item": [
        {
          "name": "Listar Productos",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/products",
              "host": ["{{baseUrl}}"],
              "path": ["products"]
